Sub ExtraerDatosTP()
    Dim wb As Workbook
    Dim ws As Worksheet
    Dim wsControl As Worksheet
    Dim wsExclusions As Worksheet
    Dim wsPais As Worksheet
    Dim lastRow As Long
    Dim lastRowControl As Long
    Dim lastRowExclusions As Long
    Dim lastRowPais As Long
    Dim i As Long, j As Long
    Dim dataMatrix() As Variant
    Dim searchValue As Variant
    Dim dict As Object
    Dim key As Variant
    Dim currentDate As Date
    Dim startDate As Date
    Dim endDate As Date
    Dim exclusionValues As Collection
    Dim exclusionValue As Variant
    Dim valueMapping As Object
    Dim isExcluded As Boolean
    Dim sortedDataMatrix() As Variant
    Dim sortedSearchValues As Variant
    Dim tempMatrix() As Variant
    Dim tempRow As Long
    Dim tempArray As Variant
    Dim paisDict As Object
    Dim paisValue As Variant
    Dim sortedKey As Variant
    Dim found As Boolean
    
    Dim basePath As String
    Dim folderPath As String
    Dim folderName As String
    Dim fileName As String
    Dim latestFile As String
    Dim latestDate As Date
    Dim cw As Integer
    Dim weekToCheck As Integer
    Dim lastWeekPrevYear As Integer
    Dim foundFolder As Boolean
    Dim jumpedToPrevYear As Boolean

    ' ==== MAPEO DE VALORES ====
    Set valueMapping = CreateObject("Scripting.Dictionary")
    valueMapping.Add "ST06", "ST06"
    valueMapping.Add "ST08", "ST08"
    valueMapping.Add "ST14", "ST14"
    valueMapping.Add "ST30", "ST30"
    valueMapping.Add "ST35", "ST35"
    valueMapping.Add "ST40", "ST40"
    valueMapping.Add "ST60", "ST60"
    valueMapping.Add "ST70", "ST70"
    valueMapping.Add "ST72", "ST72"
    valueMapping.Add "OSI", "ST08"
    valueMapping.Add "CIG", "ST06"

    ' ==== HOJA PANEL DE CONTROL ====
    Set wsControl = ThisWorkbook.Sheets("PANEL DE CONTROL")
    lastRowControl = wsControl.Cells(wsControl.Rows.Count, "B").End(xlUp).row

    If lastRowControl > 2 Then
        wsControl.Range("B3:D" & lastRowControl).ClearContents
    End If

    ' ==== LOCALIZAR CARPETA CWxx Y ARCHIVO MÁS RECIENTE (SOPORTA CAMBIO DE AÑO) ====
    basePath = "\\spi60001\A400M\FAL_INDUSTRIAL_MANAGEMENT\04 Master Plan\01.15 Tactical Plan\"

    ' Semana actual ISO
    cw = DatePart("ww", Date, vbMonday, vbFirstFourDays)
    'cw = "2"
    ' Queremos CW-1
    weekToCheck = cw - 1

    ' Si pasamos a 0, calcular última semana del año anterior (52 o 53)
    If weekToCheck < 1 Then
        lastWeekPrevYear = DatePart("ww", DateSerial(Year(Date) - 1, 12, 28), vbMonday, vbFirstFourDays)
        weekToCheck = lastWeekPrevYear
        jumpedToPrevYear = True
    Else
        jumpedToPrevYear = False
    End If

    foundFolder = False
    Do While weekToCheck >= 1 And Not foundFolder
        folderName = "CW" & Format(weekToCheck, "00") & "\1.- Definitivo FAL\"
        folderPath = basePath & folderName

        On Error Resume Next
        If Dir(folderPath, vbDirectory) <> "" Then
            foundFolder = True
        Else
            weekToCheck = weekToCheck - 1
            If weekToCheck < 1 And Not jumpedToPrevYear Then
                ' Saltamos por primera vez al año anterior: última semana ISO del año anterior
                lastWeekPrevYear = DatePart("ww", DateSerial(Year(Date) - 1, 12, 28), vbMonday, vbFirstFourDays)
                weekToCheck = lastWeekPrevYear
                jumpedToPrevYear = True
            End If
        End If
        On Error GoTo 0
    Loop

    If Not foundFolder Then
        MsgBox "No se ha encontrado ninguna carpeta CWxx válida en la ruta especificada.", vbExclamation
        Exit Sub
    End If

    ' Buscar el archivo más reciente con el patrón TAOAI. Master Plan CW*.xlsx
    latestFile = ""
    latestDate = #1/1/1900#

    fileName = Dir(folderPath & "TAOAI. Tactical Plan CW*.xlsx")
    Do While fileName <> ""
        If FileDateTime(folderPath & fileName) > latestDate Then
            latestDate = FileDateTime(folderPath & fileName)
            latestFile = folderPath & fileName
        End If
        fileName = Dir
    Loop

    If latestFile = "" Then
        MsgBox "No se ha encontrado ningún archivo 'TAOAI. Tactical Plan CW*.xlsx' en " & folderPath, vbExclamation
        Exit Sub
    End If

    ' Abrir el archivo encontrado
    Set wb = Workbooks.Open(latestFile, ReadOnly:=True)
    Set ws = wb.Sheets("Tactical Plan Project View")

    ' ==== LECTURA Y PROCESADO DE DATOS ====
    lastRow = ws.Cells(ws.Rows.Count, "A").End(xlUp).row

    Set dict = CreateObject("Scripting.Dictionary")

    ' Exclusiones
    Set wsExclusions = ThisWorkbook.Sheets("Exclusiones")
    lastRowExclusions = wsExclusions.Cells(wsExclusions.Rows.Count, "A").End(xlUp).row
    Set exclusionValues = New Collection
    For i = 1 To lastRowExclusions
        exclusionValues.Add wsExclusions.Cells(i, 1).Value
    Next i

    ' Primera pasada: fecha más antigua (columna 4)
   '--- 1ª pasada: fecha más antigua (columna 4) -----------------
    For i = 2 To lastRow
        For Each searchValue In valueMapping.Keys
            '   <--  NUEVO:  solo comparamos el prefijo  <--
            If Left(ws.Cells(i, 3).Value, Len(searchValue)) = searchValue Then
                key = ws.Cells(i, 1).Value & "_" & valueMapping(searchValue)
                If Not dict.Exists(key) Then
                    dict.Add key, Array(ws.Cells(i, 1).Value, _
                                       valueMapping(searchValue), _
                                       ws.Cells(i, 4).Value, _
                                       Empty)                     'campo de fin todavía vacío
                End If
            End If
        Next searchValue
    Next i

    ' Segunda pasada: fecha más reciente (columna 5)
  '--- 2ª pasada: fecha más reciente (columna 5) ----------------
    For i = lastRow To 2 Step -1
        For Each searchValue In valueMapping.Keys
            If Left(ws.Cells(i, 3).Value, Len(searchValue)) = searchValue Then
                key = ws.Cells(i, 1).Value & "_" & valueMapping(searchValue)
                If dict.Exists(key) Then
                    If IsEmpty(dict(key)(3)) Then
                        tempArray = dict(key)
                        tempArray(3) = ws.Cells(i, 5).Value   'fecha fin
                        dict(key) = tempArray
                    End If
                End If
            End If
        Next searchValue
    Next i

    ' Matriz desde diccionario
    ReDim dataMatrix(1 To dict.Count, 1 To 4)
    j = 1
    For Each key In dict.Keys
        dataMatrix(j, 1) = dict(key)(0)
        dataMatrix(j, 2) = dict(key)(1)
        dataMatrix(j, 3) = dict(key)(2)
        dataMatrix(j, 4) = dict(key)(3)
        j = j + 1
    Next key

    ' Cerrar archivo origen
    wb.Close SaveChanges:=False

    currentDate = Date

    ' Contar filas válidas
    tempRow = 1
    For i = 1 To UBound(dataMatrix, 1)
        startDate = CDate(dataMatrix(i, 3))
        endDate = CDate(dataMatrix(i, 4))
        If currentDate >= startDate And currentDate <= endDate Then
            isExcluded = False
            On Error Resume Next
            For Each exclusionValue In exclusionValues
                If dataMatrix(i, 1) = exclusionValue Then
                    isExcluded = True
                    Exit For
                End If
            Next exclusionValue
            On Error GoTo 0

            If Not isExcluded Then
                tempRow = tempRow + 1
            End If
        End If
    Next i

    ' Crear tempMatrix depurada
    ReDim tempMatrix(1 To tempRow - 1, 1 To 4)
    tempRow = 1
    For i = 1 To UBound(dataMatrix, 1)
        startDate = CDate(dataMatrix(i, 3))
        endDate = CDate(dataMatrix(i, 4))
        If currentDate >= startDate And currentDate <= endDate Then
            isExcluded = False
            On Error Resume Next
            For Each exclusionValue In exclusionValues
                If dataMatrix(i, 1) = exclusionValue Then
                    isExcluded = True
                    Exit For
                End If
            Next exclusionValue
            On Error GoTo 0

            If Not isExcluded Then
                tempMatrix(tempRow, 1) = dataMatrix(i, 1)
                tempMatrix(tempRow, 2) = dataMatrix(i, 2)
                tempMatrix(tempRow, 3) = dataMatrix(i, 3)
                tempMatrix(tempRow, 4) = dataMatrix(i, 4)
                tempRow = tempRow + 1
            End If
        End If
    Next i

    
    
' ==== ORDENAR SEGÚN LISTA STxx, **manteniendo TODOS los MSN** ====
sortedSearchValues = Array("ST06", "ST08", "ST14", "ST30", "ST35", "ST40", "ST60", "ST70", "ST72")

' Contar cuántas filas tendrá la tabla final:
Dim filasTotales As Long
filasTotales = 0
For Each sortedKey In sortedSearchValues
    For i = 1 To UBound(tempMatrix, 1)
        If tempMatrix(i, 2) = sortedKey Then filasTotales = filasTotales + 1
    Next i
    ' Si una ST no tiene MSN, también queremos una fila “-”
    filasTotales = filasTotales + 1
Next

' Reservar la matriz de salida:
ReDim sortedDataMatrix(1 To filasTotales, 1 To 4)

Dim pos As Long
pos = 1

' Primero, copiar **todas** las filas que tengan MSN:
For Each sortedKey In sortedSearchValues
    For i = 1 To UBound(tempMatrix, 1)
        If tempMatrix(i, 2) = sortedKey Then
            sortedDataMatrix(pos, 1) = tempMatrix(i, 1)   ' MSN
            sortedDataMatrix(pos, 2) = tempMatrix(i, 2)   ' ST
            sortedDataMatrix(pos, 3) = tempMatrix(i, 3)   ' fecha inicio
            sortedDataMatrix(pos, 4) = tempMatrix(i, 4)   ' fecha fin
            pos = pos + 1
        End If
    Next i

    ' ----------  INSERTAR fila “-”  ----------
    If pos = 1 Then                     ' nunca había fila ? siempre la insertamos
        sortedDataMatrix(pos, 1) = "-"
        sortedDataMatrix(pos, 2) = sortedKey
        sortedDataMatrix(pos, 3) = "-"
        sortedDataMatrix(pos, 4) = "-"
        pos = pos + 1
    ElseIf sortedDataMatrix(pos - 1, 2) <> sortedKey Then   ' la fila anterior es de otra ST
        sortedDataMatrix(pos, 1) = "-"
        sortedDataMatrix(pos, 2) = sortedKey
        sortedDataMatrix(pos, 3) = "-"
        sortedDataMatrix(pos, 4) = "-"
        pos = pos + 1
    End If
Next sortedKey

    
    

    ' Volcar a PANEL DE CONTROL
    wsControl.Range("B3:D" & lastRowControl).ClearContents
    j = 3
    For i = 1 To UBound(sortedDataMatrix, 1)
        If Not IsEmpty(sortedDataMatrix(i, 1)) Then
            wsControl.Cells(j, 2).Value = sortedDataMatrix(i, 1)
            wsControl.Cells(j, 3).Value = sortedDataMatrix(i, 2)
            wsControl.Cells(j, 4).Value = sortedDataMatrix(i, 4)
            j = j + 1
        End If
    Next i

    ' ==== CRUCE CON PESTAÑA PAIS ====
    Set wsPais = ThisWorkbook.Sheets("PAIS")
    lastRowPais = wsPais.Cells(wsPais.Rows.Count, "A").End(xlUp).row

    Set paisDict = CreateObject("Scripting.Dictionary")
    For i = 1 To lastRowPais
        paisDict(wsPais.Cells(i, 1).Value) = wsPais.Cells(i, 2).Value
    Next i

    For i = 3 To j - 1
        paisValue = wsControl.Cells(i, 2).Value
        If paisDict.Exists(paisValue) Then
            wsControl.Cells(i, 5).Value = paisDict(paisValue)
        Else
            wsControl.Cells(i, 5).Value = ""
        End If
    Next i
End Sub

